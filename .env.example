# Gamdl Docker Configuration

# Host interface to bind the WebUI on. Default 0.0.0.0 (all interfaces).
# Set to a specific IP to restrict access — e.g. a Tailscale IP, 127.0.0.1, etc.
BIND_HOST=0.0.0.0

# Host port for the WebUI (container always serves on 3000).
WEBUI_PORT=3000

# Frequency of checks in seconds (default: 3600 = 1 hour)
# Options: 1800 (30min), 3600 (1hr), 7200 (2hrs), 14400 (4hrs), 86400 (daily)
FREQUENCY=3600

# Output directory for downloaded music
OUTPUT_LOCATION=/data/music

# Host path mounted to /data/music in containers.
# For Navidrome integration on Atmos, set: /data/media/music
MUSIC_HOST_PATH=./downloads

# Playlist file export directory (m3u/m3u8)
PLAYLIST_M3U_DIR=/data/music/playlists

# Folder structure template
# Variables: {artist}, {album}, {title}, {tracknumber}
OUTPUT_STRUCTURE={artist}/{album}/{title}

# Audio file format
# Options: m4a, mp3, flac
FILE_FORMAT=m4a

# Download lyrics
# Options: true, false
DOWNLOAD_LYRICS=true

# Lyrics file format
# Options: lrc (synced), txt (plain)
LYRICS_FORMAT=lrc

# Timezone for scheduling
TZ=America/New_York

# Docker socket path (for webui to trigger downloads)
DOCKER_SOCKET=/var/run/docker.sock

# Downloader mode (recommended: nm3u8dlre)
# Options: nm3u8dlre, ffmpeg
DOWNLOAD_MODE=nm3u8dlre

# Auto update downloader tools inside the container
AUTO_UPDATE=true

# Auto update interval in seconds (default: 86400 = 24 hours)
AUTO_UPDATE_INTERVAL=86400

# Keep false unless you explicitly want nightly gamdl upgrades
AUTO_UPDATE_GAMDL=false
